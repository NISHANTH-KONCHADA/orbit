# Orbit Server — Environment Variables
# Copy this file to .env and fill in your values

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/orbit?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ── Gemini AI (add up to 3 keys for auto-rotation on quota limits) ────────────
GEMINI_KEY_1=your_gemini_api_key_1
GEMINI_KEY_2=your_gemini_api_key_2
GEMINI_KEY_3=your_gemini_api_key_3

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
